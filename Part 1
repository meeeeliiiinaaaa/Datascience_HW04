      "source": [
        "# data validation\n",
        "def validate_no_missing(df):\n",
        "\n",
        "    missing = df.isnull().sum().sum()\n",
        "    if missing > 0:\n",
        "        print(f\"Dataset contains {missing} missing values.\")\n",
        "\n",
        "    return df\n",
        "\n",
        "\n",
        "def validate_positive_values(df):\n",
        "\n",
        "    numeric = df.select_dtypes(include=np.number)\n",
        "\n",
        "    if (numeric < 0).any().any():\n",
        "        raise ValueError(\"Negative values detected.\")\n",
        "\n",
        "    return df"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {
        "id": "eJVxVkEU_VI1"
      },
      "source": [
        "Here we defined two functions to validate data, tells us the number of missing values and alert if we have negative values."
      ]
    },
    {
      "cell_type": "code",
      "execution_count": 39,
      "metadata": {
        "id": "awkyknDmxtUY"
      },
      "outputs": [],
      "source": [
        "# create pipeline\n",
        "def load_and_clean_data():\n",
        "    df = (\n",
        "        load_data()\n",
        "        .pipe(standardize_column_names)\n",
        "        .pipe(remove_duplicates)\n",
        "        .pipe(validate_no_missing)\n",
        "        .pipe(validate_positive_values)\n",
        "    )\n",
        "    print(df.head())\n",
        "    return df\n"
      ]
    },
