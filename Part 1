      "source": [
        "# define data cleaning functions\n",
        "\n",
        "def load_data(path=\"uom190346a/global-coffee-health-dataset\", name='synthetic_coffee_health_10000.csv'):\n",
        "\n",
        "   dataset_path = kagglehub.dataset_download(path)\n",
        "   csv_file_path = os.path.join(dataset_path, name)\n",
        "   df = pd.read_csv(csv_file_path)\n",
        "   return df\n",
        "\n",
        "def standardize_column_names(df):\n",
        "\n",
        "    df = df.copy()\n",
        "    df.columns = (\n",
        "        df.columns.str.strip()\n",
        "                  .str.lower()\n",
        "                  .str.replace(\" \", \"_\")\n",
        "    )\n",
        "    return df\n",
        "\n",
        "def remove_duplicates(df):\n",
        "\n",
        "    return df.drop_duplicates()\n"
      ]
    },
